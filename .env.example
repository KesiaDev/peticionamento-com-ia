# =============================================================================
# Supabase Configuration
# =============================================================================
# Copy this file to .env and fill in the values from `supabase status`

# Public URL of the Supabase API (used by the frontend via Vite)
VITE_SUPABASE_URL=http://localhost:54321

# Public publishable key (safe to expose in the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Legacy alias accepted in some setups
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only, NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection URL (for migrations and admin tasks)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# =============================================================================
# Lovable Cloud Configuration
# =============================================================================
# Set to true only if you have deployed the Supabase Edge Functions manually.
# Default is false, which uses client-side API calls (Lovable-compatible).
VITE_USE_EDGE_FUNCTIONS=false
